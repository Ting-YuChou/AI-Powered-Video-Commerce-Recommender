      "id": 2,
      "targets": [
        {
          "expr": "sum by (job) (rate(video_commerce_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (job) (rate(video_commerce_http_requests_total[5m])), 1)",
