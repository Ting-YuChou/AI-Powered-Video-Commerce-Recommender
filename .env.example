# AI-Powered Video Commerce Recommender - Environment Configuration
# ===================================================================
# Copy this file to .env and configure with your settings
# DO NOT commit .env file to version control

# ====================
# API Configuration
# ====================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false
API_WORKERS=1
API_API_KEY=
API_API_KEY_FILE=
SECURITY_AUTH_MODE=api_key
SECURITY_INTERNAL_SERVICE_KEY=
SECURITY_INTERNAL_SERVICE_KEY_FILE=

# ====================
# Redis Configuration
# ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_PASSWORD_FILE=

# ====================
# Postgres Configuration
# ====================
POSTGRES_PASSWORD=
DATABASE_URL=
DATABASE_URL_FILE=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# ====================
# Model Configuration
# ====================
MODEL_DEVICE=auto
MODEL_CLIP_MODEL=openai/clip-vit-large-patch14
MODEL_CACHE_DIR=/tmp/models
MODEL_BATCH_SIZE=32

# ====================
# Vector Search Configuration
# ====================
VECTOR_INDEX_PATH=/tmp/models/vector_index.faiss
VECTOR_EMBEDDING_DIM=512

# ====================
# Recommendation Engine Configuration
# ====================
RECOMMENDATION_CF_INDEX_PATH=/tmp/models/cf_vector_index.faiss
RECOMMENDATION_CF_WEIGHT=0.4
RECOMMENDATION_CONTENT_WEIGHT=0.3
RECOMMENDATION_POPULARITY_WEIGHT=0.3
RECOMMENDATION_RETRIEVAL_EXECUTOR_WORKERS=2
RECOMMENDATION_SERVING_RECENT_INTERACTION_LIMIT=0

# ====================
# Ranking Throughput Configuration
# ====================
RANKING_BATCH_MAX_REQUESTS=64
RANKING_BATCH_TARGET_REQUESTS=32
RANKING_BATCH_WAIT_MS=48
RANKING_BATCH_QUEUE_SIZE=32768
RANKING_BATCH_RUNNER_COUNT=16
RANKING_COORDINATOR_DISPATCH_CONCURRENCY=16
RANKING_RUNNER_QUEUE_SIZE=0
RANKING_RUNNER_BATCH_CONCURRENCY=1
RANKING_INFERENCE_EXECUTOR_WORKERS=16
RANKING_INFERENCE_PROCESS_WORKERS=0
RANKING_MAX_QUEUE_WAIT_MS=150
RANKING_RUNNER_PAYLOAD_V2_ENABLED=true
RANKING_RUNNER_PAYLOAD_MAX_BYTES=33554432

SERVICE_GATEWAY_WORKERS=4
SERVICE_RECOMMENDATION_WORKERS=4
SERVICE_RANKING_WORKERS=4
SERVICE_RANKING_SERVICE_URLS=http://ranking-service:8003
SERVICE_RANKING_COORDINATOR_HOST=ranking-coordinator
SERVICE_RANKING_COORDINATOR_PORT=8013
SERVICE_RANKING_COORDINATOR_CLIENT_POOL_SIZE=128
SERVICE_RANKING_COORDINATOR_DIRECT_ENABLED=true
SERVICE_RANKING_COORDINATOR_REQUEST_TIMEOUT_SECONDS=2
SERVICE_RANKING_RUNNER_URLS=ranking-runner:8014
SERVICE_RANKING_RUNNER_PORT=8014
SERVICE_RANKING_RUNNER_CONNECT_TIMEOUT_SECONDS=1
SERVICE_RANKING_RUNNER_REQUEST_TIMEOUT_SECONDS=1.5
SERVICE_RANKING_RUNNER_UNHEALTHY_COOLDOWN_SECONDS=0.2
SERVICE_RANKING_RUNNER_DNS_REFRESH_SECONDS=5
SERVICE_RANKING_RUNNER_ENDPOINT_MISSING_REFRESHES=3
SERVICE_RANKING_RUNNER_ENDPOINT_MISSING_GRACE_SECONDS=30
SERVICE_RANKING_SINGLE_COORDINATOR_ENABLED=true
SERVICE_PROXY_MAX_CONNECTIONS=2000
SERVICE_PROXY_MAX_KEEPALIVE_CONNECTIONS=1000
SERVICE_MAX_INFLIGHT_RECOMMENDATIONS=40
RANKING_RUNNER_REPLICAS=16

# ====================
# Cache Configuration
# ====================
CACHE_ENABLE_CACHING=true
CACHE_DEFAULT_TTL=3600
CACHE_CANDIDATE_CACHE_RACE_TIMEOUT_MS=5
CACHE_RECOMMENDATION_CACHE_RACE_TIMEOUT_MS=5
CACHE_BACKGROUND_TASK_QUEUE_SIZE=8192
CACHE_BACKGROUND_TASK_WORKER_COUNT=4
RECOMMENDATION_KNOWN_USER_SNAPSHOT_ENABLED=true
RECOMMENDATION_KNOWN_USER_SNAPSHOT_REFRESH_INTERVAL_SECONDS=60
RECOMMENDATION_KNOWN_USER_SNAPSHOT_MAX_USERS=200000
RECOMMENDATION_CONTENT_FEATURES_SNAPSHOT_ENABLED=true
RECOMMENDATION_CONTENT_FEATURES_SNAPSHOT_REFRESH_INTERVAL_SECONDS=60
RECOMMENDATION_CONTENT_FEATURES_SNAPSHOT_MAX_ITEMS=100000

# ====================
# Monitoring Configuration
# ====================
MONITORING_LOG_LEVEL=INFO
MONITORING_ENABLE_METRICS=true
MONITORING_ENABLE_PROMETHEUS_METRICS=true
MONITORING_ENABLE_TRACING=true
MONITORING_TRACING_SAMPLE_RATE=0.01
MONITORING_REQUEST_LOG_SAMPLE_RATE=0.01
MONITORING_ERROR_REQUEST_LOG_SAMPLE_RATE=0.01
MONITORING_PROFILING_LOG_SAMPLE_RATE=0.001
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# ====================
# Data Configuration
# ====================
DATA_LOAD_SAMPLE_DATA=true
DATA_UPLOAD_DIR=/tmp/uploads

# ====================
# Kafka Configuration
# ====================
KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false
KAFKA_CONSUMER_HANDLER_RETRIES=3
KAFKA_CONSUMER_HANDLER_RETRY_BACKOFF_MS=250
KAFKA_DEAD_LETTER_ENABLE=true
KAFKA_DEAD_LETTER_TOPIC=dead-letter-events

# ====================
# Object Storage
# ====================
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=video-commerce-assets
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_ACCESS_KEY_ID_FILE=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_SECRET_ACCESS_KEY_FILE=
OBJECT_STORAGE_CONNECT_TIMEOUT_SECONDS=5
OBJECT_STORAGE_READ_TIMEOUT_SECONDS=60
OBJECT_STORAGE_MAX_ATTEMPTS=3
OBJECT_STORAGE_CHECKSUM_ALGORITHM=
OBJECT_STORAGE_SERVER_SIDE_ENCRYPTION=

# ====================
# Environment
# ====================
ENVIRONMENT=development
