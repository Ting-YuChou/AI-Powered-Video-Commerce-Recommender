# AI Video Commerce Recommender - Environment Configuration
# =========================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env file to version control

# =============================================================================
# API Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false
API_WORKERS=1

# CORS settings (comma-separated origins)
API_CORS_ORIGINS=*
API_CORS_CREDENTIALS=true

# Request limits
# 100MB
API_MAX_REQUEST_SIZE=104857600
API_REQUEST_TIMEOUT=30
API_MAX_CONCURRENT_REQUESTS=100

# Security
# Required in production when SECURITY_AUTH_MODE uses api_key.
API_API_KEY=
# Preferred in production when using docker secrets or mounted secret files.
API_API_KEY_FILE=
# Requests per minute. Default is sized for 1000 QPS public-edge validation.
API_RATE_LIMIT_REQUESTS=120000

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Required in production.
REDIS_PASSWORD=
REDIS_PASSWORD_FILE=
REDIS_DECODE_RESPONSES=true
REDIS_MAX_CONNECTIONS=1000
REDIS_SOCKET_TIMEOUT=30
REDIS_SOCKET_CONNECT_TIMEOUT=30
REDIS_RETRY_ON_TIMEOUT=true

# =============================================================================
# Machine Learning Model Configuration
# =============================================================================
# CLIP model settings
MODEL_CLIP_MODEL=openai/clip-vit-large-patch14
MODEL_EMBEDDING_DIM=512

# Model paths (optional - leave empty for default)
MODEL_RANKING_MODEL_PATH=
MODEL_CF_MODEL_PATH=

# Processing settings
MODEL_CACHE_DIR=/tmp/models
MODEL_DEVICE=auto
MODEL_BATCH_SIZE=32
MODEL_MAX_VIDEO_LENGTH=300
MODEL_NUM_KEYFRAMES=8
MODEL_FFMPEG_FRAME_EXTRACTION_ENABLED=true
MODEL_FFMPEG_TIMEOUT_SECONDS=30
MODEL_FFMPEG_TARGET_WIDTH=640
MODEL_SPEECH_TO_TEXT_ENABLED=false
MODEL_SPEECH_TO_TEXT_BASE_URL=http://asr-service:8010
MODEL_SPEECH_TO_TEXT_MODEL=Qwen/Qwen3-ASR-0.6B
MODEL_SPEECH_TO_TEXT_TIMEOUT_SECONDS=120
MODEL_SPEECH_TO_TEXT_MAX_ATTEMPTS=2
MODEL_SPEECH_TO_TEXT_MAX_TRANSCRIPT_CHARS=4000
ASR_MAX_CONCURRENT_TRANSCRIPTIONS=1
ASR_QUEUE_WAIT_SECONDS=5

# Performance settings
MODEL_ENABLE_QUANTIZATION=false
MODEL_ENABLE_GPU=true
MODEL_MAX_CONCURRENT_REQUESTS=10

# =============================================================================
# Vector Search Configuration
# =============================================================================
VECTOR_INDEX_PATH=/tmp/models/vector_index.faiss
VECTOR_EMBEDDING_DIM=512
VECTOR_INDEX_TYPE=HNSW

# HNSW parameters
VECTOR_HNSW_M=32
VECTOR_HNSW_EF_CONSTRUCTION=200
VECTOR_HNSW_EF_SEARCH=50

# Search parameters
VECTOR_SEARCH_K=100
VECTOR_SIMILARITY_THRESHOLD=0.1

# =============================================================================
# Recommendation Engine Configuration
# =============================================================================
# Collaborative filtering
RECOMMENDATION_CF_FACTORS=64
RECOMMENDATION_CF_REGULARIZATION=0.1
RECOMMENDATION_CF_ITERATIONS=50
RECOMMENDATION_CF_INDEX_PATH=/tmp/models/cf_vector_index.faiss
RECOMMENDATION_TT_ARCHITECTURE=dcn
RECOMMENDATION_TT_CROSS_LAYERS=3
RECOMMENDATION_RETRIEVAL_EXECUTOR_WORKERS=2
RECOMMENDATION_SERVING_RECENT_INTERACTION_LIMIT=0

# Candidate generation
RECOMMENDATION_CANDIDATES_PER_SOURCE=100
RECOMMENDATION_MAX_TOTAL_CANDIDATES=500
RECOMMENDATION_ENABLE_CF_COLD_START_BOOTSTRAP=false
RECOMMENDATION_CF_COLD_START_METHOD=hybrid_adapter_neighbors
RECOMMENDATION_CF_COLD_START_NEIGHBORS=20
RECOMMENDATION_CF_COLD_START_MIN_VALID_NEIGHBORS=5
RECOMMENDATION_CF_COLD_START_MIN_CLIP_SIMILARITY=0.35
RECOMMENDATION_CF_COLD_START_SOFTMAX_TEMPERATURE=0.07
RECOMMENDATION_CF_COLD_START_NEIGHBOR_WEIGHT=0.65
RECOMMENDATION_CF_COLD_START_MAX_ITEMS=500
RECOMMENDATION_CF_COLD_START_MAX_AGE_DAYS=30
RECOMMENDATION_CF_COLD_START_MAX_INTERACTIONS=5
RECOMMENDATION_MAX_NEW_ITEM_CANDIDATES=10
RECOMMENDATION_NEW_ITEM_POOL_REFRESH_INTERVAL_SECONDS=300
RECOMMENDATION_SPEECH_CATEGORY_CANDIDATES_ENABLED=false

# Ranking weights (should sum to ~1.0)
RECOMMENDATION_CF_WEIGHT=0.4
RECOMMENDATION_CONTENT_WEIGHT=0.3
RECOMMENDATION_POPULARITY_WEIGHT=0.3

# Trending algorithm
RECOMMENDATION_TRENDING_DECAY_FACTOR=0.95
RECOMMENDATION_TRENDING_WINDOW_HOURS=24

# Diversity settings
RECOMMENDATION_ENABLE_DIVERSITY=true
RECOMMENDATION_DIVERSITY_FACTOR=0.1
RECOMMENDATION_MAX_ITEMS_PER_CATEGORY=3
RECOMMENDATION_ENABLE_SLATE_DIVERSITY=false
RECOMMENDATION_SLATE_DIVERSITY_METHOD=mmr
RECOMMENDATION_MMR_LAMBDA=0.8
RECOMMENDATION_MMR_RERANK_POOL_MULTIPLIER=5
RECOMMENDATION_MMR_MIN_RERANK_POOL_SIZE=50
RECOMMENDATION_MMR_MAX_RERANK_POOL_SIZE=100

# =============================================================================
# Ranking Model Configuration
# =============================================================================
RANKING_MODEL_TYPE=neural
RANKING_ARCHITECTURE=dcn
RANKING_CROSS_LAYERS=3
RANKING_LOW_RANK_DIM=8
RANKING_HIDDEN_DIMS=256,128,64
RANKING_DROPOUT_RATE=0.2
RANKING_LEARNING_RATE=0.001
RANKING_ENABLE_ASYNC_BATCHING=true
RANKING_BATCH_MAX_REQUESTS=64
RANKING_BATCH_TARGET_REQUESTS=32
RANKING_BATCH_WAIT_MS=48
RANKING_BATCH_QUEUE_SIZE=32768
RANKING_BATCH_RUNNER_COUNT=16
RANKING_COORDINATOR_DISPATCH_CONCURRENCY=16
RANKING_RUNNER_QUEUE_SIZE=0
RANKING_RUNNER_BATCH_CONCURRENCY=1
RANKING_INFERENCE_EXECUTOR_WORKERS=16
RANKING_INFERENCE_PROCESS_WORKERS=0
RANKING_MAX_QUEUE_WAIT_MS=150
RANKING_OFFLOAD_INFERENCE_TO_THREAD=true
RANKING_PRODUCT_FEATURE_CACHE_SIZE=50000
RANKING_RUNNER_PAYLOAD_V2_ENABLED=true
RANKING_RUNNER_PAYLOAD_MAX_BYTES=33554432

# Multi-objective optimization
RANKING_ENABLE_MULTI_OBJECTIVE=true
RANKING_CTR_WEIGHT=1.0
RANKING_CVR_WEIGHT=2.0
RANKING_GMV_WEIGHT=3.0

# Training settings
RANKING_EPOCHS=100
RANKING_BATCH_SIZE=1024
RANKING_EARLY_STOPPING_PATIENCE=10

# =============================================================================
# Service Topology / 1000 QPS Profile
# =============================================================================
SERVICE_GATEWAY_WORKERS=4
SERVICE_RECOMMENDATION_WORKERS=4
SERVICE_RANKING_WORKERS=4
SERVICE_RECOMMENDATION_SERVICE_URLS=http://recommendation-service:8001
SERVICE_RANKING_SERVICE_URLS=http://ranking-service:8003
SERVICE_RANKING_COORDINATOR_HOST=ranking-coordinator
SERVICE_RANKING_COORDINATOR_PORT=8013
SERVICE_RANKING_COORDINATOR_CLIENT_POOL_SIZE=128
SERVICE_RANKING_COORDINATOR_DIRECT_ENABLED=true
SERVICE_RANKING_COORDINATOR_REQUEST_TIMEOUT_SECONDS=2
SERVICE_RANKING_RUNNER_URLS=ranking-runner:8014
SERVICE_RANKING_RUNNER_PORT=8014
SERVICE_RANKING_RUNNER_CONNECT_TIMEOUT_SECONDS=1
SERVICE_RANKING_RUNNER_REQUEST_TIMEOUT_SECONDS=1.5
SERVICE_RANKING_RUNNER_UNHEALTHY_COOLDOWN_SECONDS=0.2
SERVICE_RANKING_RUNNER_DNS_REFRESH_SECONDS=5
SERVICE_RANKING_RUNNER_ENDPOINT_MISSING_REFRESHES=3
SERVICE_RANKING_RUNNER_ENDPOINT_MISSING_GRACE_SECONDS=30
SERVICE_PROXY_MAX_CONNECTIONS=2000
SERVICE_PROXY_MAX_KEEPALIVE_CONNECTIONS=1000
SERVICE_MAX_INFLIGHT_RECOMMENDATIONS=40
SERVICE_RANKING_SERVICE_FALLBACK_ENABLED=false
SERVICE_RANKING_SINGLE_COORDINATOR_ENABLED=true
RANKING_SERVICE_REPLICAS=1
RANKING_RUNNER_REPLICAS=16

# =============================================================================
# Cache Configuration
# =============================================================================
CACHE_ENABLE_CACHING=true
CACHE_DEFAULT_TTL=3600
CACHE_CANDIDATE_CACHE_RACE_TIMEOUT_MS=5
CACHE_RECOMMENDATION_CACHE_RACE_TIMEOUT_MS=5
CACHE_BACKGROUND_TASK_QUEUE_SIZE=8192
CACHE_BACKGROUND_TASK_WORKER_COUNT=4
RECOMMENDATION_KNOWN_USER_SNAPSHOT_ENABLED=true
RECOMMENDATION_KNOWN_USER_SNAPSHOT_REFRESH_INTERVAL_SECONDS=60
RECOMMENDATION_KNOWN_USER_SNAPSHOT_MAX_USERS=200000
RECOMMENDATION_CONTENT_FEATURES_SNAPSHOT_ENABLED=true
RECOMMENDATION_CONTENT_FEATURES_SNAPSHOT_REFRESH_INTERVAL_SECONDS=60
RECOMMENDATION_CONTENT_FEATURES_SNAPSHOT_MAX_ITEMS=100000

# Specific cache TTLs
CACHE_USER_FEATURES_TTL=1800
CACHE_CONTENT_FEATURES_TTL=86400
CACHE_RECOMMENDATIONS_TTL=900

# Cache size limits
CACHE_MAX_CACHE_SIZE=10000
CACHE_CLEANUP_INTERVAL=3600

# Intelligent caching
CACHE_ADAPTIVE_TTL=true
CACHE_HIGH_ACTIVITY_TTL=300
CACHE_LOW_ACTIVITY_TTL=7200

# =============================================================================
# Monitoring and Logging Configuration
# =============================================================================
MONITORING_LOG_LEVEL=INFO
MONITORING_LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Metrics collection
MONITORING_ENABLE_METRICS=true
MONITORING_METRICS_INTERVAL=60

# Health checks
MONITORING_HEALTH_CHECK_INTERVAL=30
MONITORING_COMPONENT_TIMEOUT=5

# Performance monitoring
MONITORING_SLOW_REQUEST_THRESHOLD=1.0
MONITORING_ENABLE_REQUEST_LOGGING=true
MONITORING_REQUEST_LOG_SAMPLE_RATE=0.01
MONITORING_ERROR_REQUEST_LOG_SAMPLE_RATE=0.01
MONITORING_PROFILING_LOG_SAMPLE_RATE=0.001
MONITORING_ENABLE_TRACING=true
MONITORING_TRACING_SAMPLE_RATE=0.01

# Alerting thresholds
MONITORING_ERROR_RATE_THRESHOLD=0.05
MONITORING_RESPONSE_TIME_THRESHOLD=500
MONITORING_MEMORY_THRESHOLD=0.8

# =============================================================================
# Data Management Configuration
# =============================================================================
# Sample data
DATA_LOAD_SAMPLE_DATA=true
DATA_SAMPLE_DATA_PATH=data/sample_products.json
DATA_SAMPLE_USERS=1000
DATA_SAMPLE_INTERACTIONS=10000

# Data storage
DATA_UPLOAD_DIR=/tmp/uploads
DATA_MAX_FILE_SIZE=524288000
DATA_ALLOWED_EXTENSIONS=.mp4,.avi,.mov,.mkv

# Data processing
DATA_CLEANUP_TEMP_FILES=true
DATA_TEMP_FILE_TTL=3600

# =============================================================================
# Kafka Configuration
# =============================================================================
KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false
KAFKA_CONSUMER_MAX_POLL_INTERVAL_MS=600000
KAFKA_CONSUMER_HANDLER_RETRIES=3
KAFKA_CONSUMER_HANDLER_RETRY_BACKOFF_MS=250
KAFKA_DEAD_LETTER_ENABLE=true
KAFKA_DEAD_LETTER_TOPIC=dead-letter-events

# =============================================================================
# Environment Settings
# =============================================================================
ENVIRONMENT=development
NO_SAMPLE_DATA=false

# =============================================================================
# Optional External Services
# =============================================================================
# Sentry (Error tracking)
# SENTRY_DSN=

# AWS S3 (File storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# Database
# Leave empty to let compose derive it from POSTGRES_PASSWORD.
DATABASE_URL=
DATABASE_URL_FILE=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
POSTGRES_USER=video_commerce
# Required in production; do not use the default password.
POSTGRES_PASSWORD=
POSTGRES_DB=video_commerce

# =============================================================================
# GPU Configuration (Optional)
# =============================================================================
# CUDA settings
# CUDA_VISIBLE_DEVICES=0
# CUDA_DEVICE_ORDER=PCI_BUS_ID

# =============================================================================
# Production Settings
# =============================================================================
# Uncomment and configure for production deployment

# Security
SECURITY_AUTH_MODE=api_key
SECURITY_INTERNAL_SERVICE_KEY=
SECURITY_INTERNAL_SERVICE_KEY_FILE=
SECURITY_OIDC_ENABLED=false
SECURITY_OIDC_REQUIRED=false
SECURITY_OIDC_ISSUER=
SECURITY_OIDC_AUDIENCE=
SECURITY_OIDC_JWKS_URL=
SECURITY_JWT_SHARED_SECRET=
SECURITY_JWT_SHARED_SECRET_FILE=
SECURITY_JWT_ALGORITHMS=RS256

# HTTPS
# SSL_CERT_FILE=/path/to/cert.pem
# SSL_KEY_FILE=/path/to/key.pem

# Monitoring services
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
# ALERTMANAGER_PORT=9093

# Load balancing
# WORKER_CONNECTIONS=1000
# KEEPALIVE_TIMEOUT=65

# =============================================================================
# Notes
# =============================================================================
# 1. For production, set ENVIRONMENT=production and disable debug/reload
# 2. Always set strong passwords for Redis and databases
# 3. Use environment-specific .env files (.env.production, .env.development)
# 4. For GPU support, ensure CUDA drivers are installed and set MODEL_DEVICE=cuda
# 5. Adjust batch sizes and worker counts based on available resources
# 6. Monitor memory usage and adjust cache sizes accordingly
# 7. Enable metrics and logging for production environments
# 8. Use external secret management for sensitive values in production
# 9. Production startup rejects empty API/internal keys, empty Redis passwords,
#    and default Postgres/MinIO credentials.

# =============================================================================
# Object Storage
# =============================================================================
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=video-commerce-assets
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_ACCESS_KEY_ID_FILE=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_SECRET_ACCESS_KEY_FILE=
OBJECT_STORAGE_PREFIX=uploads
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_CREATE_BUCKET_ON_STARTUP=false
OBJECT_STORAGE_CONNECT_TIMEOUT_SECONDS=5
OBJECT_STORAGE_READ_TIMEOUT_SECONDS=60
OBJECT_STORAGE_MAX_ATTEMPTS=3
OBJECT_STORAGE_CHECKSUM_ALGORITHM=
OBJECT_STORAGE_SERVER_SIDE_ENCRYPTION=
