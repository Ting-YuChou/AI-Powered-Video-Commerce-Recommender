# AI Video Commerce Recommender - Environment Configuration
# =========================================================
# Copy this file to .env and update with your actual values.
# This is the single source of truth for local environment configuration.
# DO NOT commit .env to version control.

# =============================================================================
# API Server Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false
API_WORKERS=1

# CORS settings (comma-separated origins)
API_CORS_ORIGINS=*
API_CORS_CREDENTIALS=true

# Request limits
API_MAX_REQUEST_SIZE=104857600
API_REQUEST_TIMEOUT=30
API_MAX_CONCURRENT_REQUESTS=100

# Security
API_API_KEY=
API_RATE_LIMIT_REQUESTS=1000

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=true
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=30
REDIS_SOCKET_CONNECT_TIMEOUT=30
REDIS_RETRY_ON_TIMEOUT=true

# =============================================================================
# Machine Learning Model Configuration
# =============================================================================
MODEL_CLIP_MODEL=openai/clip-vit-large-patch14
MODEL_EMBEDDING_DIM=512

# Model paths (optional - leave empty for default)
MODEL_RANKING_MODEL_PATH=
MODEL_CF_MODEL_PATH=

# Processing settings
MODEL_CACHE_DIR=/tmp/models
MODEL_DEVICE=auto
MODEL_BATCH_SIZE=32
MODEL_MAX_VIDEO_LENGTH=300
MODEL_NUM_KEYFRAMES=8

# Performance settings
MODEL_ENABLE_QUANTIZATION=false
MODEL_ENABLE_GPU=true
MODEL_MAX_CONCURRENT_REQUESTS=10

# =============================================================================
# Vector Search Configuration
# =============================================================================
VECTOR_INDEX_PATH=/tmp/vector_index.faiss
VECTOR_EMBEDDING_DIM=512
VECTOR_INDEX_TYPE=HNSW

# HNSW parameters
VECTOR_HNSW_M=32
VECTOR_HNSW_EF_CONSTRUCTION=200
VECTOR_HNSW_EF_SEARCH=50

# Search parameters
VECTOR_SEARCH_K=100
VECTOR_SIMILARITY_THRESHOLD=0.1

# =============================================================================
# Recommendation Engine Configuration
# =============================================================================
# Collaborative filtering (legacy NMF settings, kept for reference)
RECOMMENDATION_CF_FACTORS=64
RECOMMENDATION_CF_REGULARIZATION=0.1
RECOMMENDATION_CF_ITERATIONS=50

# Two-Tower retrieval model settings
RECOMMENDATION_TT_EMBEDDING_DIM=128
RECOMMENDATION_TT_USER_HIDDEN_DIMS=256,128
RECOMMENDATION_TT_ITEM_HIDDEN_DIMS=256,128
RECOMMENDATION_TT_LEARNING_RATE=0.001
RECOMMENDATION_TT_BATCH_SIZE=1024
RECOMMENDATION_TT_EPOCHS=20
RECOMMENDATION_TT_TEMPERATURE=0.07

# Negative sampling
RECOMMENDATION_TT_NUM_HARD_NEGATIVES=5
RECOMMENDATION_TT_NUM_RANDOM_NEGATIVES=10
RECOMMENDATION_TT_HARD_NEGATIVE_RATIO_START=0.1
RECOMMENDATION_TT_HARD_NEGATIVE_RATIO_END=0.5

# CF retrieval / serving
RECOMMENDATION_CF_INDEX_PATH=/app/models/cf_vector_index.faiss
RECOMMENDATION_CANDIDATES_PER_SOURCE=100
RECOMMENDATION_MAX_TOTAL_CANDIDATES=500
RECOMMENDATION_ENABLE_USER_EMBEDDING_PUBLISH=true
RECOMMENDATION_ENABLE_SEGMENT_CANDIDATE_PRECOMPUTE=true
RECOMMENDATION_SEGMENT_CANDIDATE_PRECOMPUTE_INTERVAL_SECONDS=240
RECOMMENDATION_SEGMENT_CANDIDATE_PRECOMPUTE_MAX_CONTENTS=8
RECOMMENDATION_SEGMENT_CANDIDATE_PRECOMPUTE_MAX_CATEGORIES=4
RECOMMENDATION_SEGMENT_CANDIDATE_PRECOMPUTE_PAGES=home,detail
RECOMMENDATION_SEGMENT_CANDIDATE_PRECOMPUTE_DEVICES=mobile,desktop

# Ranking weights
RECOMMENDATION_CF_WEIGHT=0.4
RECOMMENDATION_CONTENT_WEIGHT=0.3
RECOMMENDATION_POPULARITY_WEIGHT=0.3

# Trending algorithm
RECOMMENDATION_TRENDING_DECAY_FACTOR=0.95
RECOMMENDATION_TRENDING_WINDOW_HOURS=24

# Diversity settings
RECOMMENDATION_ENABLE_DIVERSITY=true
RECOMMENDATION_DIVERSITY_FACTOR=0.1
RECOMMENDATION_MAX_ITEMS_PER_CATEGORY=3

# =============================================================================
# Ranking Model Configuration
# =============================================================================
RANKING_MODEL_TYPE=neural
RANKING_HIDDEN_DIMS=256,128,64
RANKING_DROPOUT_RATE=0.2
RANKING_LEARNING_RATE=0.001

# Multi-objective optimization
RANKING_ENABLE_MULTI_OBJECTIVE=true
RANKING_CTR_WEIGHT=1.0
RANKING_CVR_WEIGHT=2.0
RANKING_GMV_WEIGHT=3.0

# Training settings
RANKING_EPOCHS=100
RANKING_BATCH_SIZE=1024
RANKING_EARLY_STOPPING_PATIENCE=10

# =============================================================================
# Cache Configuration
# =============================================================================
CACHE_ENABLE_CACHING=true
CACHE_DEFAULT_TTL=3600

# Specific cache TTLs
CACHE_USER_FEATURES_TTL=1800
CACHE_CONTENT_FEATURES_TTL=86400
CACHE_RECOMMENDATIONS_TTL=900
CACHE_CANDIDATE_TTL=300
CACHE_USER_EMBEDDING_TTL=1800
CACHE_PRODUCT_METADATA_TTL=86400
CACHE_SERVING_POOL_TTL=1800

# Cache size limits
CACHE_MAX_CACHE_SIZE=10000
CACHE_CLEANUP_INTERVAL=3600

# Intelligent caching
CACHE_ADAPTIVE_TTL=true
CACHE_HIGH_ACTIVITY_TTL=300
CACHE_LOW_ACTIVITY_TTL=7200

# =============================================================================
# Monitoring and Logging Configuration
# =============================================================================
MONITORING_LOG_LEVEL=INFO
MONITORING_LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
MONITORING_ENABLE_METRICS=true
MONITORING_ENABLE_PROMETHEUS_METRICS=true
MONITORING_METRICS_INTERVAL=60
MONITORING_HEALTH_CHECK_INTERVAL=30
MONITORING_COMPONENT_TIMEOUT=5
MONITORING_SLOW_REQUEST_THRESHOLD=1.0
MONITORING_ENABLE_REQUEST_LOGGING=true
MONITORING_ENABLE_PROFILING_LOGS=false
MONITORING_PROFILING_LOG_MIN_DURATION_MS=250
MONITORING_ERROR_RATE_THRESHOLD=0.05
MONITORING_RESPONSE_TIME_THRESHOLD=500
MONITORING_MEMORY_THRESHOLD=0.8

# =============================================================================
# Service Topology / Gateway Proxy Configuration
# =============================================================================
SERVICE_PROXY_CONNECT_TIMEOUT_SECONDS=5.0
SERVICE_PROXY_READ_TIMEOUT_SECONDS=10.0
SERVICE_PROXY_WRITE_TIMEOUT_SECONDS=10.0
SERVICE_PROXY_POOL_TIMEOUT_SECONDS=15.0
SERVICE_PROXY_MAX_CONNECTIONS=500
SERVICE_PROXY_MAX_KEEPALIVE_CONNECTIONS=100
SERVICE_PROXY_KEEPALIVE_EXPIRY_SECONDS=5.0
SERVICE_TRAINER_INTERVAL_SECONDS=3600
SERVICE_GATEWAY_WORKERS=2
SERVICE_RECOMMENDATION_WORKERS=2
SERVICE_INTERACTION_WORKERS=2

# =============================================================================
# Data Management Configuration
# =============================================================================
DATA_LOAD_SAMPLE_DATA=true
DATA_USE_CSV_DATASET=false
DATA_DATASET_DIR=Dataset
DATA_SAMPLE_DATA_PATH=data/sample_products.json
DATA_SAMPLE_USERS=1000
DATA_SAMPLE_INTERACTIONS=10000
DATA_UPLOAD_DIR=/tmp/uploads
DATA_MAX_FILE_SIZE=524288000
DATA_ALLOWED_EXTENSIONS=.mp4,.avi,.mov,.mkv
DATA_CLEANUP_TEMP_FILES=true
DATA_TEMP_FILE_TTL=3600

# =============================================================================
# Environment Settings
# =============================================================================
ENVIRONMENT=development
NO_SAMPLE_DATA=false

# =============================================================================
# Optional External Services
# =============================================================================
# SENTRY_DSN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# =============================================================================
# Production Notes
# =============================================================================
# 1. Set ENVIRONMENT=production and disable debug/reload for production use.
# 2. Use strong passwords and an external secret manager for sensitive values.
# 3. Keep .env local; do not commit it to the repository.
