# Isolated Qwen3-ASR GPU service with a bounded internal transcription adapter.
FROM python:3.12-slim

ARG APP_UID=10001
ARG APP_GID=10001

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV HF_HOME=/models/huggingface
ENV HUGGINGFACE_HUB_CACHE=/models/huggingface/hub

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.asr.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.asr.txt

COPY asr_service ./asr_service
RUN groupadd --system --gid "${APP_GID}" appuser \
    && useradd --system --uid "${APP_UID}" --gid appuser --home-dir /app --shell /bin/bash appuser \
    && mkdir -p /models/huggingface \
    && chown -R appuser:appuser /app /models

USER appuser

EXPOSE 8010
HEALTHCHECK --interval=30s --timeout=10s --start-period=180s --retries=5 \
    CMD curl -fsS http://localhost:8010/health || exit 1

CMD ["python", "-m", "uvicorn", "asr_service.api:app", "--host", "0.0.0.0", "--port", "8010"]
